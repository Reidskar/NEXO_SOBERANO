# ==================== DISCORD BOT ====================

# Token del bot de Discord (obtener de https://discord.com/developers/applications)
# Pasos: 1. Ir a Discord Developer Portal
#        2. Crear nueva aplicación
#        3. Ir a "Bot" y crear bot
#        4. Copiar el token bajo "TOKEN"
DISCORD_TOKEN=your_bot_token_here

# ID de la aplicación Discord (obtener de https://discord.com/developers/applications)
# Se encuentra en la página principal de la aplicación como "APPLICATION ID"
DISCORD_CLIENT_ID=your_client_id_here

# ID del servidor Discord (opcional, para comandos locales)
DISCORD_GUILD_ID=

# ==================== NEXO BACKEND ====================

# URL del backend NEXO_CORE
NEXO_BACKEND=http://127.0.0.1:8000

# API Key para autenticación con NEXO_CORE
NEXO_API_KEY=NEXO_LOCAL_2026_OK

# URL de FastAPI (alternativa)
FASTAPI_URL=http://127.0.0.1:8000

# ==================== CARACTERÍSTICAS ====================

# Auto-chat: Responder automáticamente en canales
AUTOCHAT_ENABLED=true

# IDs de canales para auto-chat (separados por comas)
AUTOCHAT_CHANNEL_IDS=

# Intervalo mínimo entre respuestas automáticas (segundos)
AUTOCHAT_MIN_INTERVAL_SECONDS=10

# Ventana de tiempo para considerar conversación activa (segundos)
AUTOCHAT_ACTIVE_WINDOW_SECONDS=180

# Máximo de mensajes de contexto para auto-chat
AUTOCHAT_MAX_CONTEXT_MESSAGES=12

# Permitir respuestas sin mención
AUTOCHAT_ALLOW_WITHOUT_MENTION=false

# Nombre del bot para menciones
AUTOCHAT_NAME=nexo

# ==================== VOZ ====================

# Mantener conexión de voz activa
VOICE_ALWAYS_ON=true

# ID del servidor para conexión de voz
VOICE_GUILD_ID=

# ID del canal de voz para conexión automática
VOICE_CHANNEL_ID=

# Silenciar el bot en canales de voz
VOICE_SELF_DEAF=true

# Segundos para intentar reconectar a voz
VOICE_RECONNECT_SECONDS=20

# ==================== LOGGING ====================

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Archivo de log
LOG_FILE=nexo_bot.log

# ==================== OPCIONES ====================

# Habilitar modo debug
DEBUG=false

# Timeout para peticiones HTTP (en ms)
REQUEST_TIMEOUT=10000

# Máximo de reintentos para conexión
MAX_RETRIES=3
