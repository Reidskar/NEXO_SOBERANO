{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend FastAPI",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Frontend Vite (React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    },
    {
      "name": "Discord Bot",
      "runtimeExecutable": "node",
      "runtimeArgs": ["discord_bot/bot.js"],
      "port": null
    },
    {
      "name": "NEXO_CORE Standalone",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "NEXO_CORE.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "port": 8001
    }
  ]
}
