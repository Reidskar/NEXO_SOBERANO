# Credenciales Computrabajo
COMPUTRABAJO_EMAIL=
COMPUTRABAJO_PASSWORD=
COMPUTRABAJO_URL=https://www.computrabajo.cl
SEARCH_URL=https://www.computrabajo.cl/trabajo-de-desarrollador

# Reglas de filtrado
MIN_SALARY_CLP=900000
MAX_DISTANCE_KM=30
KEYWORDS_REQUIRED=python,backend,ia

# IA Claude (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=auto
MIN_AI_SCORE=7

# Notificaciones Android
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=nexo-alertas

# Google Sheets (opcional)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Runtime
DEVICE_ID=DESKTOP-1
DRY_RUN=true
CYCLE_HOURS=4
MAX_CYCLE_RETRIES=2
RETRY_BACKOFF_SECONDS=20
MAX_APPLICATIONS_PER_CYCLE=1
PLAYWRIGHT_HEADLESS=true

# Coordinación entre dispositivos (opcional)
# Ejemplo OneDrive compartido:
# STATE_DIR=C:/Users/TU_USUARIO/OneDrive/NEXO_SHARED/agente_postulaciones
STATE_DIR=
LOCK_STALE_MINUTES=90

# Perfil CV estructurado para scoring IA (ruta local o absoluta)
CV_PROFILE_FILE=cv_profile.json
