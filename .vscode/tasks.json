      "group": "none",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "🧠 Gemma4: Revisar código (git diff)",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe scripts\\nexo_manager.py review",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🧠 Gemma4: Auditoría de seguridad",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe scripts\\nexo_manager.py security",
