      "problemMatcher": []
    },
    {
      "label": "🔧 NEXO: Auto-reparar código",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --scan --fix",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
