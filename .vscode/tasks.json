    {
      "label": "📦 NEXO: Instalar dependencias",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt --upgrade",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🌐 NEXO: Abrir War Room en navegador",
      "type": "shell",
      "command": "start NEXO_SOBERANO_v3.html",
      "windows": {
        "command": "start NEXO_SOBERANO_v3.html"
      },
      "linux": {
        "command": "xdg-open NEXO_SOBERANO_v3.html"
      },
      "osx": {
        "command": "open NEXO_SOBERANO_v3.html"
      },
      "group": "build",
