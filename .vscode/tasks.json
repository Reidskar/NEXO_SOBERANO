    {
      "label": "🧠 NEXO: Seguimiento IA activo",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe scripts\\ai_context_tracker.py --watch --interval 180",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Iniciando seguimiento IA activo",
          "endsPattern": "Contexto IA actualizado"
        }
      }
    }
  ]
}