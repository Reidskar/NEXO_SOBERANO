{
  // ═══════════════════════════════════════════════════════
  // NEXO SOBERANO — Tareas VSCode
  // ═══════════════════════════════════════════════════════
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🎯 NEXO: Inicio Automático (Orquestador)",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe INICIO_RAPIDO.py",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "⚙️ NEXO: Configurar OBS Profesionalmente",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe obs_control\\configure_obs.py",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "📱 NEXO: Programar móvil/tablet (stream)",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe obs_control\\setup_mobile_stream.py",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 NEXO: Escaneo de código",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --scan",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔧 NEXO: Auto-reparar código",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --scan --fix",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "👁 NEXO: Watch continuo (auto-fix)",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --watch --fix --interval 20",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*\\.py):(\\d+).*$",
          "file": 1,
          "line": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Iniciando escaneo",
          "endsPattern": "Reporte guardado"
        }
      }
    },
    {
      "label": "📊 NEXO: Ver último reporte",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --report",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🤖 NEXO: Mejora con IA",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe nexo_autosupervisor.py --improve",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 NEXO: Iniciar Backend",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe run_backend.py",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🧪 NEXO: Tests del Backend",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pytest test_backend.py -v --tb=short",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "🔄 NEXO: Sync completo",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe scripts\\run_unified_sync_full.py",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "📁 NEXO: Sync Drive únicamente",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe scripts\\run_drive_classification.py",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
