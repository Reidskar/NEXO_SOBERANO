{
    // ═══════════════════════════════════════════════════════
    // NEXO SOBERANO — Configuración VSCode Optimizada
    // ═══════════════════════════════════════════════════════
    // ─── PYTHON ───
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.formatting.provider": "black",
    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.mypyEnabled": false,
    "python.linting.pylintEnabled": false,
    // ─── EDITOR ───
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit"
    },
    "editor.rulers": [
        100,
        120
    ],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.trimAutoWhitespace": true,
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.inlineSuggest.enabled": true,
    "editor.suggest.preview": true,
    "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', Consolas, monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.lineHeight": 1.6,
    // ─── TERMINAL ───
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.env.windows": {
        "PYTHONPATH": "${workspaceFolder}",
        "NEXO_ENV": "development"
    },
    // ─── ARCHIVOS ───
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/node_modules": true,
        "**/.supervisor_backups": true,
        "**/dist": true,
        "**/build": true,
        "**/*.egg-info": true
    },
    "files.watcherExclude": {
        "**/__pycache__/**": true,
        "**/node_modules/**": true,
        "**/.supervisor_backups/**": true,
        "**/logs/**": true
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 2000,
    // ─── GIT ───
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "gitHistory.showAll": true,
    // ─── EXPLORADOR ───
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.sortOrder": "type",
    // ─── COPILOT / IA ───
    "github.copilot.enable": {
        "*": true,
        "python": true,
        "javascript": true,
        "html": true
    },
    "github.copilot.editor.enableAutoCompletions": true,
    // ─── WORKSPACE TRUST ───
    "security.workspace.trust.untrustedFiles": "open",
    // ─── TEMAS Y UI ───
    "workbench.colorTheme": "One Dark Pro",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.tree.indent": 16,
    // ─── NEXO SUPERVISOR - Tarea automática en guardado ───
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.py$",
                "isAsync": true,
                "cmd": "python ${workspaceFolder}/nexo_autosupervisor.py --scan --dir ${workspaceFolder}"
            }
        ]
    }
}