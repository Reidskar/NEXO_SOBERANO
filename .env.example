# Configuración NEXO SOBERANO - Plantilla de Ejemplo
# Renombra este archivo a .env y completa los valores reales

# --- BASE DE DATOS (Supabase / Postgres) ---
# Usa el Pooler (puerto 5432 o 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- SUPABASE API ---
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=[TU_ANON_KEY]
SUPABASE_SERVICE_KEY=[TU_SERVICE_ROLE_KEY]
PGBOUNCER_MODE=transaction

# --- INFRAESTRUCTURA LOCAL ---
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# --- INTELIGENCIA ARTIFICIAL ---
GEMINI_API_KEY=[TU_GEMINI_KEY]
ELEVENLABS_API_KEY=[TU_ELEVENLABS_KEY]
OPENAI_API_KEY=[TU_OPENAI_KEY]

# --- INTEGRACIONES ---
DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=[TU_WEBHOOK]
OBS_ENABLED=false
OBS_PASSWORD=[TU_OBS_PASS]

# --- SEGURIDAD ---
NEXO_API_KEY=[TU_API_KEY_PARA_EL_BACKEND]
NEXO_WEBHOOK_SECRET=[TU_SECRET_PARA_HMAC]
