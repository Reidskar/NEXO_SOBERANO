# Ejemplo de conexión Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres.[tu-id]:[tu-password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Variables recomendadas para backend profesional
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname   # ← OBTÉN ESTA DE SUPABASE/RAILWAY
SECRET_KEY=tu-clave-secreta
NEXO_PUBLIC_BASE_URL=https://elanarcocapital.com
# ====================================
# NEXO SOBERANO - Configuración Completa
# ====================================

# ---- CONFIGURACIÓN GENERAL ----
DOMAIN=nexo.local
EMAIL=admin@nexo.local
ENVIRONMENT=production
DEBUG=false
API_URL=https://api.nexo.app
FRONTEND_URL=https://app.nexo.app

# ---- SEGURIDAD JWT ----
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ---- IA - OPENAI (Copilot) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
# Opcional: endpoint OpenAI-compatible (útil para integración tipo Copilot API gateway)
OPENAI_BASE_URL=

# ---- IA - GOOGLE (Gemini + Workspace) ----
GEMINI_API_KEY=AIza-your-key-here
GOOGLE_API_KEY=AIzaSyxxx-your-key-here
GOOGLE_CREDENTIALS_JSON=/path/to/credentials.json
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# ---- IA - ANTHROPIC (Claude) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Router LLM backend: auto|anthropic|grok|openai|copilot|gemini
NEXO_LLM_PROVIDER=auto

# ---- IA - MICROSOFT (Outlook + Azure) ----
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:8000/auth/outlook/callback

# ---- EMAIL SMTP (para notificaciones) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Nexo Noticias

# ---- BASE DE DATOS ----
DATABASE_URL=sqlite:////app/data/nexo.db
CONVERSATIONS_DB=conversations.db
PREFERENCES_DB=preferences.db
NOTIFICATIONS_DB=notifications.db
CALENDAR_DB=calendar.db

# ---- OMNICANAL - TELEGRAM ----
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN=123456:ABCDEFxxx
TELEGRAM_CHAT_ID=your_chat_id

# ---- OMNICANAL - WHATSAPP ----
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_BUSINESS_PHONE_ID=xxx
WHATSAPP_ACCESS_TOKEN=xxx

# ---- OMNICANAL - DISCORD ----
DISCORD_BOT_TOKEN=your-discord-token
DISCORD_GUILD_ID=xxx
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# ---- OMNICANAL - FACEBOOK ----
FACEBOOK_PAGE_TOKEN=xxx
FACEBOOK_VERIFY_TOKEN=xxx

# ---- OMNICANAL - INSTAGRAM ----
INSTAGRAM_ACCESS_TOKEN=xxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=xxx

# ---- NEWS & SOURCES ----
NEWS_API_KEY=your-newsapi-key
GUARDIAN_API_KEY=your-guardian-key
RSS_FEEDS=https://feed1.com,https://feed2.com

# ---- OBS STREAMING ----
OBS_WEBSOCKET_URL=ws://localhost:4455
OBS_WEBSOCKET_PASSWORD=password

# ---- CACHE & PERFORMANCE ----
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_MINUTES=30

# ---- LOGGING ----
LOG_LEVEL=INFO
LOG_FILE=/var/log/nexo/app.log

# ---- PUERTOS ----
BACKEND_PORT=8000
FRONTEND_PORT=8080

# ---- RATE LIMITING ----
API_RATE_LIMIT=10/s
CHAT_RATE_LIMIT=30/m
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- SESIONES ----
SESSION_TIMEOUT=86400

# ---- WEBHOOKS ----
WEBHOOK_SECRET=your-webhook-secret-here

# ---- MONITORING ----
SENTRY_DSN=your-sentry-dsn-here

# ---- SUPABASE GRAFANA (Observability) ----
# Single-project monitoring: fill out project ref and service role key
# Find these at: https://app.supabase.com/project/_/settings/api-keys
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
# Multi-project monitoring: use an access token instead
# Generate one at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Optionally filter multi-project monitoring to a single organization
SUPABASE_ORGANIZATION_ID=
# Grafana dashboard password protection (set to "true" to require login)
GRAFANA_PASSWORD_PROTECTED=true
# Set a strong password for the Grafana admin user (username: admin)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
GRAFANA_PASSWORD=change-me-in-production

# ---- NOTIFICACIONES ----
DEFAULT_NOTIFICATION_FREQUENCY=daily
AUTO_REDUCE_NOTIFICATIONS=true
NOTIFICATION_RETENTION_DAYS=90

# ---- ADMIN ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_EMAIL=admin@nexo.app

# ---- FEATURES EXPERIMENTALES ----
ENABLE_VOICE_TRANSCRIPTION=false
ENABLE_PDF_EXPORT=false
ENABLE_ADVANCED_ANALYTICS=false

# ====================================
# GO-LIVE DRIVE -> YOUTUBE (MÍNIMO)
# ====================================
# Puedes usar credenciales compartidas:
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# o específicas por servicio:
# DRIVE_CLIENT_ID / DRIVE_CLIENT_SECRET
# YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DRIVE_CLIENT_ID=
DRIVE_CLIENT_SECRET=
DRIVE_PROJECT_ID=nexo-soberano-drive
DRIVE_ROOT_FOLDER_ID=

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_PROJECT_ID=nexo-soberano
YOUTUBE_CHANNEL_ID=

# ---- X (Twitter) + xAI (Grok) ----
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_USERNAME=
X_BOT_USERNAME=
XAI_API_KEY=
XAI_API_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL=grok-beta
NEXO_X_AUTO_PUBLISH=false
NEXO_X_GROK_VALIDATE=false
X_BEARER_TOKEN=
NEXO_X_MONITOR_INTERVAL_SECONDS=900
GOOGLE_STITCH_WEBHOOK_URL=
GOOGLE_STITCH_API_KEY=
NEXO_PUBLIC_BASE_URL=

# Tunables producción pipeline diario
NEXO_API_DELAY_SECONDS=0.5
NEXO_VIDEO_BITRATE=1000k

# ---- NEXO CORE (backend consolidado) ----
NEXO_HOST=0.0.0.0
NEXO_PORT=8000
NEXO_LOG_LEVEL=INFO
NEXO_LOG_FILE=nexo_core.log
NEXO_MAX_TOKENS_DIA=900000
NEXO_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://localhost:8000

# OBS integration (desactivado por defecto)
OBS_ENABLED=false
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=
OBS_RECONNECT_SECONDS=5

# Discord integration (desactivado por defecto)
DISCORD_ENABLED=false
DISCORD_RECONNECT_SECONDS=15

# ---- OneDrive sin Azure (fallback local) ----
# auto: intenta Graph y si falla usa carpeta local OneDrive
# local: fuerza solo carpeta local
# graph: fuerza Microsoft Graph
NEXO_ONEDRIVE_SOURCE=auto
# Opcional: ruta manual de carpeta OneDrive sincronizada
NEXO_ONEDRIVE_LOCAL_DIR=
# Intentar iniciar OneDrive.exe automáticamente si no está corriendo (1/0)
NEXO_ONEDRIVE_AUTO_START=1
